# ─────────────────────────────────────────────────────────
#  Plantilla de variables de entorno para el proyecto LangGraph
#  Copia este archivo como .env y rellena tus valores reales.
#  ¡NUNCA subas el archivo .env a git!
# ─────────────────────────────────────────────────────────

# Azure AI Foundry — Endpoint y clave
# Encuéntralo en: Azure Portal → tu recurso Azure OpenAI → Claves y punto de conexión
AZURE_OPENAI_ENDPOINT=https://<tu-recurso>.openai.azure.com/
AZURE_OPENAI_API_KEY=<tu-clave-azure-aqui>

# Nombre del deployment del modelo de chat (ej: gpt-4o-mini, gpt-4o)
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini

# Nombre del deployment del modelo de embeddings (para RAG)
AZURE_OPENAI_EMBEDDINGS_DEPLOYMENT=text-embedding-ada-002

# Versión de la API de Azure OpenAI (no cambiar salvo necesidad)
AZURE_OPENAI_API_VERSION=2024-02-01

# OpenWeatherMap API Key (opcional — si no la pones, el clima será simulado)
# Obtén la tuya en: https://openweathermap.org/api (plan gratuito disponible)
OPENWEATHER_API_KEY=<tu-clave-openweather-aqui>
